# ================================
# tradebot runtime essentials
# ================================

# Required for server boot (production requires strong secret length)
SESSION_SECRET=replace-with-32+char-secret

# Required for DB-backed runtime state / auth / persistence
DATABASE_URL=postgres://user:password@host:5432/dbname

# Agent authentication key (recommend 32+ chars)
AGENT_KEY=replace-with-32+char-agent-key

# Optional provider keys
OPENAI_API_KEY=
KIWOOM_APP_KEY=
KIWOOM_APP_SECRET=
KIWOOM_APP_KEY_REAL=
KIWOOM_APP_SECRET_REAL=
KIWOOM_APP_KEY_MOCK=
KIWOOM_APP_SECRET_MOCK=
